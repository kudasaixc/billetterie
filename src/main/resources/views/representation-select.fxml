<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.maa.controllers.RepresentationSelectController"
      spacing="15" prefWidth="700" prefHeight="500">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <children>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Sélection de la représentation" styleClass="h2" />
            <TextField fx:id="searchField" promptText="Filtrer par date ou salle" HBox.hgrow="ALWAYS"/>
        </HBox>

        <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableReps" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                    <TableColumn fx:id="colDate" text="Date" prefWidth="200" />
                    <TableColumn fx:id="colSalle" text="Salle" prefWidth="200" />
                    <TableColumn fx:id="colPlaces" text="Places restantes" prefWidth="150" />
                    <TableColumn fx:id="colPrix" text="Prix (€)" prefWidth="120" />
                </columns>
            </TableView>
            <Pagination fx:id="pagination" />
        </VBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#cancel" />
            <Button text="Sélectionner" onAction="#select" />
        </HBox>
    </children>
</VBox>
