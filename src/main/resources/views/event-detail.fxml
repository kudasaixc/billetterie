<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Spinner?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.TextFlow?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="fr.maa.controllers.EventDetailController"
            prefWidth="820" prefHeight="520">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" padding="12">
            <Button text="Retour" onAction="#back" />
            <Label fx:id="titleLabel" styleClass="h1" />
        </HBox>
    </top>

    <center>
        <HBox spacing="16" padding="24">
            <StackPane fx:id="imageContainer" prefWidth="280" prefHeight="360"
                       style="-fx-background-color: #f3f4f6; -fx-border-color: #e5e7eb; -fx-border-radius: 8; -fx-background-radius: 8;">
                <ImageView fx:id="spectacleImage" fitWidth="260" fitHeight="340" preserveRatio="true" />
            </StackPane>

            <VBox spacing="16" alignment="TOP_LEFT" prefWidth="480">
                <TextFlow fx:id="descriptionFlow" prefWidth="460" />

                <VBox spacing="8">
                    <Label text="Choisissez une représentation" styleClass="h2" />
                    <ComboBox fx:id="representationCombo" prefWidth="320" />
                </VBox>

                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="Quantité" />
                    <Spinner fx:id="quantitySpinner" prefWidth="120" />
                </HBox>

                <HBox spacing="20">
                    <Label text="Prix" />
                    <Label fx:id="priceLabel" styleClass="h2" />
                    <Label fx:id="availabilityLabel" />
                </HBox>

                <Label fx:id="errorLabel" style="-fx-text-fill: #dc2626;" />

                <Button text="Acheter" onAction="#startPurchase" styleClass="primary-button" prefWidth="200" />
            </VBox>
        </HBox>
    </center>

</BorderPane>
