<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.maa.controllers.BilletListController"
      spacing="20">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <children>
        <HBox styleClass="search-bar">
            <Label text="Billetterie" styleClass="h1" />
            <TextField fx:id="searchField" promptText="Rechercher un billet" />
        </HBox>

        <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableBillets" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colNumero" text="Numéro"/>
                    <TableColumn fx:id="colSpectacle" text="Spectacle"/>
                    <TableColumn fx:id="colClient" text="Client"/>
                    <TableColumn fx:id="colDate" text="Date d'achat"/>
                    <TableColumn fx:id="colPrix" text="Prix"/>
                </columns>
            </TableView>

            <Pagination fx:id="pagination" />
        </VBox>

        <HBox styleClass="actions-bar">
            <Button fx:id="addButton" text="+ Nouveau billet" onAction="#addBillet"/>
            <Button text="Retour" onAction="#back"/>
        </HBox>
    </children>
</VBox>
