<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.maa.controllers.RepresentationListController"
      spacing="20" padding="20">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <children>
        <HBox styleClass="search-bar">
            <Label text="Représentations" styleClass="h1" />
            <TextField fx:id="searchField" promptText="Rechercher une représentation" />
        </HBox>

        <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableReps" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colSpectacle" text="Spectacle"/>
                    <TableColumn fx:id="colDate" text="Date"/>
                    <TableColumn fx:id="colSalle" text="Salle"/>
                </columns>
            </TableView>

            <Pagination fx:id="pagination" />
        </VBox>

        <HBox styleClass="actions-bar">
            <Button text="Ajouter" onAction="#addRepresentation"/>
            <Button text="Supprimer" onAction="#deleteRepresentation"/>
            <Button text="Retour" onAction="#back"/>
        </HBox>
    </children>
</VBox>
