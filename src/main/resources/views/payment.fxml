<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>
<?import java.net.URL?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.maa.controllers.PaymentController"
      spacing="12" alignment="CENTER" prefWidth="420" prefHeight="420">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <padding>
        <Insets top="24" right="24" bottom="24" left="24" />
    </padding>

    <children>
        <Label text="Paiement" styleClass="h1" />
        <Label fx:id="summaryLabel" />
        <Label fx:id="totalLabel" styleClass="h2" />

        <TextField fx:id="cardNumberField" promptText="Numéro de carte" />
        <TextField fx:id="expiryField" promptText="Date d'expiration (MM/AA)" />
        <TextField fx:id="cvvField" promptText="CVV" />

        <Label text="(Les informations peuvent être factices pour tester)" styleClass="muted" />
        <Label fx:id="errorLabel" style="-fx-text-fill: #dc2626;" />

        <Button fx:id="confirmButton" text="Valider le paiement" onAction="#confirmPayment" styleClass="primary-button" />
        <Button text="Annuler" onAction="#cancel" />
    </children>
</VBox>
