<?xml version="1.0" encoding="UTF-8"?>

<GridPane xmlns="http://javafx.com/javafx/21"
          xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="fr.maa.controllers.RepresentationFormController"
          padding="20" hgap="10" vgap="10">

    <children>
        <Label text="ID Spectacle" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldIdSpectacle" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Date/heure (YYYY-MM-DDTHH:MM)" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldDateHeure" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Salle" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="fieldSalle" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <HBox spacing="10" alignment="CENTER" GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2">
            <Button text="Enregistrer" onAction="#save"/>
            <Button text="Annuler" onAction="#cancel"/>
        </HBox>
    </children>

</GridPane>
