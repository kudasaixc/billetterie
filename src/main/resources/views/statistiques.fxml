<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.maa.controllers.StatistiquesController"
      spacing="20">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <children>
        <Label fx:id="titleLabel" text="Statistiques de remplissage" styleClass="h1" />

        <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableStats" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colSpectacle" text="Spectacle" prefWidth="280" />
                    <TableColumn fx:id="colPlacesTotales" text="Places totales" prefWidth="120" />
                    <TableColumn fx:id="colBilletsVendus" text="Billets vendus" prefWidth="120" />
                    <TableColumn fx:id="colPlacesRestantes" text="Places restantes" prefWidth="130" />
                    <TableColumn fx:id="colTaux" text="Taux de remplissage" prefWidth="160" />
                </columns>
            </TableView>
        </VBox>

        <HBox styleClass="actions-bar">
            <Button text="Retour" onAction="#back"/>
        </HBox>
    </children>
</VBox>
