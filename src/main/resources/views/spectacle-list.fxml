<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.maa.controllers.SpectacleListController"
      spacing="20">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <children>
        <HBox styleClass="search-bar">
            <Label text="Spectacles" styleClass="h1" />
            <TextField fx:id="searchField" promptText="Rechercher un spectacle" />
        </HBox>

        <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableSpectacles" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID"/>
                    <TableColumn fx:id="colTitre" text="Titre"/>
                    <TableColumn fx:id="colLieu" text="Lieu"/>
                    <TableColumn fx:id="colLangue" text="Langue"/>
                </columns>
            </TableView>

            <Pagination fx:id="pagination" />
        </VBox>

        <HBox styleClass="actions-bar">
            <Button text="Ajouter" onAction="#addSpectacle"/>
            <Button text="Modifier" onAction="#editSpectacle"/>
            <Button text="Supprimer" onAction="#deleteSpectacle"/>
            <Button text="Retour" onAction="#back"/>
        </HBox>
    </children>
</VBox>
