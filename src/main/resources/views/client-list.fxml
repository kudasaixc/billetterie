<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.maa.controllers.ClientListController"
      spacing="20">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <children>
        <HBox styleClass="search-bar">
            <Label text="Clients" styleClass="h1" />
            <TextField fx:id="searchField" promptText="Rechercher un client" />
        </HBox>

        <VBox styleClass="card" spacing="15" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableClients" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" />
                    <TableColumn fx:id="colPseudo" text="Pseudo" />
                    <TableColumn fx:id="colNom" text="Nom" />
                    <TableColumn fx:id="colPrenom" text="Prenom" />
                    <TableColumn fx:id="colEmail" text="Email" />
                </columns>
            </TableView>

            <Pagination fx:id="pagination" />
        </VBox>

        <HBox styleClass="actions-bar">
            <Button text="Ajouter" onAction="#addClient" />
            <Button text="Modifier" onAction="#editClient" />
            <Button text="Supprimer" onAction="#deleteClient" />
            <Button text="Retour" onAction="#back" />
        </HBox>
    </children>
</VBox>
