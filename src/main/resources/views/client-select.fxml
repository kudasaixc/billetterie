<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Pagination?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="fr.maa.controllers.ClientSelectController"
      spacing="15" prefWidth="640" prefHeight="480">

    <stylesheets>
        <URL value="@../application.css" />
    </stylesheets>

    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <children>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Sélection du client" styleClass="h2" />
            <TextField fx:id="searchField" promptText="Rechercher par nom, email..." HBox.hgrow="ALWAYS"/>
        </HBox>

        <VBox styleClass="card" spacing="10" VBox.vgrow="ALWAYS">
            <TableView fx:id="tableClients" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                    <TableColumn fx:id="colPrenom" text="Prénom" prefWidth="150" />
                    <TableColumn fx:id="colNom" text="Nom" prefWidth="150" />
                    <TableColumn fx:id="colEmail" text="Email" prefWidth="220" />
                </columns>
            </TableView>
            <Pagination fx:id="pagination" />
        </VBox>

        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button text="Annuler" onAction="#cancel" />
            <Button text="Sélectionner" onAction="#select" />
        </HBox>
    </children>
</VBox>
